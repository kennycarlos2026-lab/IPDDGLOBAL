# IPDD Drive Proxy — Variables de Entorno

# Estas variables deben configurarse en Railway / Render como
# Environment Variables (NO subir este archivo a GitHub con datos reales)

# El contenido JSON del archivo service-account.json, en una sola línea
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"ipdd-app",...}

# Puerto (Railway/Render lo asignan automáticamente via PORT)
PORT=3001
